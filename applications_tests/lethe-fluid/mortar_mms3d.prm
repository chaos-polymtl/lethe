# Checks the 3D matrix-based mortar implementation for a MMS case.

# Listing of Parameters
#----------------------

set dimension = 3

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method            = steady
  set number mesh adapt = 2
  set output frequency  = 0
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  subsection fluid 0
    set kinematic viscosity = 1.000
  end
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = gmsh
  set file name          = ../../stator_mesh_3d.msh
  set initial refinement = 0
end

#---------------------------------------------------
# Manifolds
#---------------------------------------------------

subsection manifolds
  set number = 2
  subsection manifold 0
    set id                = 4
    set type              = cylindrical
    set point coordinates = 0, 0, 0
    set direction vector  = 0, 0, 1
  end
  subsection manifold 1
    set id                = 7
    set type              = cylindrical
    set point coordinates = 0, 0, 0
    set direction vector  = 0, 0, 1
  end
end

#---------------------------------------------------
# Mortar
#---------------------------------------------------

subsection mortar
  set enable = true
  subsection mesh
    set type      = gmsh
    set file name = ../../rotor_mesh_3d.msh
  end
  set rotor boundary id  = 7
  set stator boundary id = 4
  set radius tolerance   = 1e-4
  subsection rotor rotation angle
    set Function expression = 0.167
  end
  set verbosity = verbose
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 2
  subsection bc 0
    set id   = 2, 3, 5, 6, 8
    set type = noslip
  end
  subsection bc 1
    set id   = 4, 7
    set type = none
  end
end

#---------------------------------------------------
# FEM
#---------------------------------------------------

subsection FEM
  set enable bubble function velocity = true
  set velocity order                  = 1
  set pressure order                  = 1
end

#---------------------------------------------------
# Source term
#---------------------------------------------------

subsection source term
  subsection fluid dynamics
    set Function constants  = h=0.6
    set Function expression = 2*pi*pi*(-3*cos(2*pi*x)+2.)*sin(pi*y)*sin(pi*(z-h))*cos(pi*y)*cos(pi*(z-h))+pi*(2*(cos(pi* y)^2)-(cos(pi*(z-h))^2))*(sin(pi*x)^3)*(sin(pi * y)^2)*(sin(pi * (z-h))^2) * cos(pi*x)    ;     2*pi*pi*(-3*cos(2*pi*y)+2) * sin(pi*x) * sin(pi*(z-h)) * cos(pi*x) * cos(pi*(z-h))+pi*(2*(cos(pi* x)^2) -(cos(pi* (z-h))^2)) * (sin(pi * x)^2) * (sin(pi * y)^3) * (sin(pi*(z-h))^2) * cos(pi * y)   ; 4*pi*pi*(3*cos(2*pi*(z-h))-2) * sin(pi*x) * sin(pi*y) * cos(pi*x) * cos(pi*y)+2*pi*((cos(pi * x)^2) + (cos(pi * y)^2)) * (sin(pi * x)^2) * (sin(pi*y)^2) * (sin(pi*(z-h))^3) * cos(pi*(z-h)); 0
  end
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable = true
  subsection uvwp
    set Function constants  = h=0.6
    set Function expression = sin(pi * x) * sin(pi * x) * cos(pi * y) * sin(pi * y) * cos(pi * (z-h)) * sin(pi * (z-h));  cos(pi * x) * sin(pi * x) * sin(pi * y) * sin(pi * y) * cos(pi * (z-h)) * sin(pi * (z-h));-2 * cos(pi * x) * sin(pi * x) * cos(pi * y) * sin(pi * y) * sin(pi * (z-h)) * sin(pi * (z-h)) ; 0
  end
end

#---------------------------------------------------
# Mesh Adaptation Control
#---------------------------------------------------

subsection mesh adaptation
  set type = uniform
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection fluid dynamics
    set tolerance      = 1e-10
    set max iterations = 10
    set verbosity      = quiet
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set method            = gmres
    set relative residual = 1e-4
    set minimum residual  = 1e-14
    set preconditioner    = amg
    set verbosity         = quiet
  end
end
