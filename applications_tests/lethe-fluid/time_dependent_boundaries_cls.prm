# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf1
  set time end         = 1
  set time step        = 0.5
  set output name      = out
  set output frequency = 0
end

#---------------------------------------------------
# Initial Conditions
#---------------------------------------------------

subsection initial conditions
  set type = nodal
end

#---------------------------------------------------
# Boundary Conditions CLS
#---------------------------------------------------

subsection boundary conditions CLS
  set number         = 4
  set time dependent = true
  subsection bc 0
    set id   = 0
    set type = dirichlet
    subsection dirichlet
      set Function expression = 1-t
    end
  end
  subsection bc 1
    set id   = 1
    set type = dirichlet
    subsection dirichlet
      set Function expression = 1-t
    end
  end
  subsection bc 2
    set id   = 2
    set type = dirichlet
    subsection dirichlet
      set Function expression = t
    end
  end
  subsection bc 3
    set id   = 3
    set type = dirichlet
    subsection dirichlet
      set Function expression = t
    end
  end
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number         = 4
  set time dependent = false
  subsection bc 0
    set id   = 0
    set type = noslip
  end
  subsection bc 1
    set id   = 1
    set type = noslip
  end
  subsection bc 2
    set id   = 2
    set type = noslip
  end
  subsection bc 3
    set id   = 3
    set type = function
    subsection u
      set Function expression = 1
    end
    subsection v
      set Function expression = 0
    end
  end
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 2
  subsection fluid 0
    set rheological model   = newtonian
    set kinematic viscosity = 0.1
    set density             = 0.1
  end
  subsection fluid 1
    set rheological model   = newtonian
    set kinematic viscosity = 100
    set density             = 100
  end
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set fluid dynamics = true
  set cls            = true
end

#---------------------------------------------------
# Post-Processing
#---------------------------------------------------

subsection post-processing
  set verbosity            = verbose
  set calculate barycenter = true
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = hyper_cube
  set grid arguments     = 0 : 1 : true
  set initial refinement = 3
end

#---------------------------------------------------
# FEM
#---------------------------------------------------

subsection FEM
  set velocity order = 1
  set pressure order = 1
  set cls order      = 1
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection fluid dynamics
    set verbosity = quiet
  end
  subsection CLS
    set verbosity = quiet
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set verbosity = quiet
  end
  subsection CLS
    set verbosity = quiet
  end
end
