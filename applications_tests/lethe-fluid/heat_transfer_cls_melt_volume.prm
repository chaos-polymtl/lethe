#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that the melt volume computation works well in a CLS
# simulation. Two superposed fluids are subject to heat on the left side of the
# domain (this is set with the initial condition).
# Only fluid 1 has a phase change specific heat model, therefore it is the only
# fluid that melts. The melt volume corresponds to the region at the
# intersection of the temperature above the liquidus temperature and the fluid 1
# subdomains.
#-------------------------------------------------------------------------------

# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf1
  set output frequency = 0
  set output name      = heat_transfer_cls_melt_volume
  set time end         = 5
  set time step        = 1
end

#---------------------------------------------------
# FEM
#---------------------------------------------------

subsection FEM
  set velocity order    = 1
  set pressure order    = 1
  set temperature order = 1
end

#---------------------------------------------------
# Initial condition
#---------------------------------------------------

subsection initial conditions
  set type = nodal
  subsection uvwp
    set Function expression = 0; 0; 0
  end
  subsection CLS
    set Function expression = 0.5 - 0.5*tanh((y-0.375)/0.03125)
  end
  subsection temperature
    set Function expression = 0.02 + 0.02*tanh((0.125-x)/0.03125)
  end
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 2
  subsection fluid 0
    set thermal conductivity = 0.001
    set specific heat        = 2000
  end
  subsection fluid 1
    set thermal conductivity model = constant
    set thermal conductivity       = 0.001

    set specific heat model = phase_change
    subsection phase change
      set latent enthalpy      = 100
      set liquidus temperature = 0.02
      set solidus temperature  = 0
      set specific heat liquid = 2000
      set specific heat solid  = 2000
    end
  end
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = hyper_cube
  set grid arguments     = 0: 0.5 : false
  set initial refinement = 4
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set fluid dynamics = true
  set heat transfer  = true
  set cls            = true
end

#---------------------------------------------------
# Post-processing
#---------------------------------------------------

subsection post-processing
  set verbosity             = verbose
  set calculate melt volume = true
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 1
  subsection bc 0
    set id   = 0
    set type = noslip
  end
end

subsection boundary conditions heat transfer
  set number = 1
  subsection bc 0
    set id   = 0
    set type = noflux
  end
end

subsection boundary conditions CLS
  set number = 1
  subsection bc 0
    set id   = 0
    set type = none
  end
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection heat transfer
    set verbosity      = quiet
    set tolerance      = 1e-12
    set max iterations = 10
  end
  subsection fluid dynamics
    set verbosity      = quiet
    set tolerance      = 1e-12
    set max iterations = 10
  end
  subsection CLS
    set tolerance      = 1e-8
    set max iterations = 10
    set verbosity      = quiet
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection heat transfer
    set verbosity                             = quiet
    set method                                = gmres
    set relative residual                     = 1e-13
    set minimum residual                      = 1e-13
    set preconditioner                        = ilu
    set ilu preconditioner fill               = 0
    set ilu preconditioner absolute tolerance = 1e-14
    set ilu preconditioner relative tolerance = 1.00
  end
  subsection CLS
    set verbosity               = quiet
    set relative residual       = 1e-3
    set minimum residual        = 1e-10
    set ilu preconditioner fill = 1
  end
end
