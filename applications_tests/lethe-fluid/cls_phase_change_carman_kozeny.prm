#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that the Carman-Kozeny permeabilty source term imposes stasis
# adequately in the solid phase for phase change simulation.
# This simulates the 2D development of a 3 layers Couette flow with 2 fluids.
# The layers are as follows:
#  - for all y in [-0.25, -0.025[: fluid 0
#  - for all y in [-0.025, 0.025[: fluid 1
#  - for all y in [0.025, 0.25[: fluid 0
# Transition between the layers is smoothened with a tanh function.
#------------------------------------------------------------------------------

# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf2
  set output frequency = 1
  set time end         = 0.3
  set time step        = 0.1
end

#---------------------------------------------------
# Initial Conditions
#---------------------------------------------------

subsection initial conditions
  set type = nodal
  subsection CLS
    set Function constants  = halfThickness=0.0003125, xInterface=0.025
    set Function expression = 0.5 - 0.5 * tanh((sqrt(y*y) - xInterface)/(2*halfThickness))
  end
end

#---------------------------------------------------
# CLS
#---------------------------------------------------

subsection CLS
  subsection interface reinitialization method
    set type      = geometric interface reinitialization
    set frequency = 1
    subsection geometric interface reinitialization
      set max reinitialization distance = 0.01875
      set tanh thickness                = 0.00625
      set transformation type           = tanh
    end
  end
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 2
  subsection fluid 0
    subsection phase change
      set latent enthalpy      = 0
      set liquidus temperature = 0.51
      set solidus temperature  = 0.49
    end
  end
  subsection fluid 1
    set density = 10
    subsection phase change
      set latent enthalpy      = 0
      set liquidus temperature = 0.51
      set solidus temperature  = 0.49
    end
  end
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable = true
  subsection uvwp
    set Function constants  = R=0.25, a=0.025, Ub=0.05, Ut=0, mu0=1, mu1=0.1
    set Function expression = if(y>=0, 0, if(y<=-a, Ub + ((Ut-Ub)/((R-a)/mu0+a/mu1))/mu0*(y+R), ((Ut-Ub)/((R-a)/mu0+a/mu1))/mu1*y)) ; 0 ; 0
  end
end

#---------------------------------------------------
# Velocity Source
#---------------------------------------------------

subsection velocity source
  set permeability model               = carman-kozeny phase change
  set Carman-Kozeny permeability area  = 5e-1
  set Carman-Kozeny division tolerance = 1e-5
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = subdivided_hyper_rectangle
  set grid arguments     = 8, 20 : -0.1, -0.25 : 0.1, 0.25 : true
  set initial refinement = 2
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 3
  subsection bc 0
    set type               = periodic
    set id                 = 0
    set periodic id        = 1
    set periodic direction = 0
  end
  subsection bc 2
    set type = noslip
    set id   = 3
  end
  subsection bc 1
    set id   = 2
    set type = function
    subsection u
      set Function expression = 0.05
    end
  end
end

#---------------------------------------------------
# Boundary Conditions Heat Transfer
#---------------------------------------------------

subsection boundary conditions heat transfer
  set number = 3
  subsection bc 0
    set type = temperature
    set id   = 2
    subsection value
      set Function expression = 1
    end
  end
  subsection bc 1
    set type = temperature
    set id   = 3
    subsection value
      set Function expression = 0
    end
  end
  subsection bc 2
    set id   = 0,1
    set type = noflux
  end
end

#---------------------------------------------------
# Boundary Conditions CLS
#---------------------------------------------------

subsection boundary conditions CLS
  set number = 2
  subsection bc 0
    set id   = 0,1
    set type = dirichlet
    subsection dirichlet
      set Function constants  = halfThickness=0.0003125, xInterface=0.025
      set Function expression = 0.5 - 0.5 * tanh((sqrt(y*y) - xInterface)/(2*halfThickness))
    end
  end
  subsection bc 1
    set id   = 2,3
    set type = dirichlet
    subsection dirichlet
      set Function expression = 0
    end
  end
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set heat transfer = true
  set cls           = true
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection heat transfer
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
  subsection fluid dynamics
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
  subsection CLS
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 15
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
  subsection heat transfer
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
  subsection CLS
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
end
