#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that the Darcy source term imposes stasis adequately in the
# solid phase for phase change simulation when simulating a two-phase flow with
# CLS.
# This simulates the 2D development of a 3 layers Couette flow with 2 fluids.
# The layers are as follows:
#  - for all y in [-0.25, -0.05[: fluid 0
#  - for all y in [-0.05, 0.05[: fluid 1
#  - for all y in [0.05, 0.25[: fluid 0
# Transition between the layers is smoothened with a tanh function.
#------------------------------------------------------------------------------

# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf2
  set output frequency = 0
  set time end         = 1
  set time step        = 0.1
end

#---------------------------------------------------
# Initial Conditions
#---------------------------------------------------

subsection initial conditions
  set type = nodal
  subsection CLS
    set Function constants  = halfThickness=0.025, xInterface=0.05
    set Function expression = 0.5 - 0.5 * tanh((sqrt(y*y) - xInterface)/(2*halfThickness))
  end
  subsection temperature
    set Function expression = -2 * y + 0.5
  end
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 2
  subsection fluid 0
    subsection phase change
      set latent enthalpy      = 0
      set liquidus temperature = 0.51
      set solidus temperature  = 0.49
      set Darcy penalty liquid = 0
      set Darcy penalty solid  = 1e8
    end
  end
  subsection fluid 1
    set density = 0.1
    subsection phase change
      set latent enthalpy      = 0
      set liquidus temperature = 0.51
      set solidus temperature  = 0.49
      set Darcy penalty liquid = 0
      set Darcy penalty solid  = 1e8
    end
  end
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable = true
  subsection uvwp
    set Function constants  = B=-0.5, a=-0.05, Ub=0.1, mu0=1, mu1=10
    set Function expression = if(y>=0, 0, if(y<=a, (Ub + (-1/mu0)*(y-B)/((a-B)*mu1-a*mu0)), (-1/mu1 * y / ((a-B)*mu1-a*mu0)))); 0; 0
  end
end

#---------------------------------------------------
# Velocity Source
#---------------------------------------------------

subsection velocity source
  set permeability model               = darcy phase change
  set enable Darcy multiply by density = true
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = subdivided_hyper_rectangle
  set grid arguments     = 4, 40 : -0.05, -0.5 : 0.05, 0.5 : true
  set initial refinement = 1
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 3
  subsection bc 0
    set type               = periodic
    set id                 = 0
    set periodic id        = 1
    set periodic direction = 0
  end
  subsection bc 2
    set type = noslip
    set id   = 3
  end
  subsection bc 1
    set id   = 2
    set type = function
    subsection u
      set Function expression = 0.1
    end
  end
end

#---------------------------------------------------
# Boundary Conditions Heat Transfer
#---------------------------------------------------

subsection boundary conditions heat transfer
  set number = 3
  subsection bc 0
    set type = temperature
    set id   = 2
    subsection value
      set Function expression = 1
    end
  end
  subsection bc 1
    set type = temperature
    set id   = 3
    subsection value
      set Function expression = 0
    end
  end
  subsection bc 2
    set id   = 0,1
    set type = noflux
  end
end

#---------------------------------------------------
# Boundary Conditions CLS
#---------------------------------------------------

subsection boundary conditions CLS
  set number = 2
  subsection bc 0
    set type               = periodic
    set id                 = 0
    set periodic id        = 1
    set periodic direction = 0
  end
  subsection bc 1
    set id   = 2,3
    set type = dirichlet
    subsection dirichlet
      set Function expression = 0
    end
  end
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set heat transfer = true
  set cls           = true
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection heat transfer
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
  subsection fluid dynamics
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
  subsection CLS
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 15
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
  subsection heat transfer
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = ilu
  end
  subsection CLS
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = ilu
  end
end
