#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that the Carman-Kozeny permeabilty source term imposes stasis
# adequately in the solid phase for phase change simulation.
# This simulates the transient development of a 2D Couette flow between parallel
# plates.
#------------------------------------------------------------------------------

# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf2
  set output frequency = 0
  set time end         = 0.50
  set time step        = 0.01
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 1
  subsection fluid 0
    subsection phase change
      set latent enthalpy      = 0
      set liquidus temperature = 0.51
      set solidus temperature  = 0.49
    end
  end
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable = true
  subsection uvwp
    set Function expression = if(y>=0.25, 0, (-4*y + 1) ); 0 ; 0
  end
end

#---------------------------------------------------
# Velocity Source
#---------------------------------------------------

subsection velocity source
  set permeability model               = carman-kozeny phase change
  set Carman-Kozeny permeability area  = 5e-6
  set Carman-Kozeny division tolerance = 1e-4
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = subdivided_hyper_rectangle
  set grid arguments     = 4, 20 : 0, 0 : 0.1, 0.5 : true
  set initial refinement = 1
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 3
  subsection bc 0
    set type               = periodic
    set id                 = 0
    set periodic id        = 1
    set periodic direction = 0
  end
  subsection bc 2
    set type = noslip
    set id   = 3
  end
  subsection bc 1
    set id   = 2
    set type = function
    subsection u
      set Function expression = 1
    end
  end
end

#---------------------------------------------------
# Boundary Conditions Heat Transfer
#---------------------------------------------------

subsection boundary conditions heat transfer
  set number = 3
  subsection bc 0
    set type = temperature
    set id   = 2
    subsection value
      set Function expression = 1
    end
  end
  subsection bc 1
    set type = temperature
    set id   = 3
    subsection value
      set Function expression = 0
    end
  end
  subsection bc 2
    set id   = 0,1
    set type = noflux
  end
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set heat transfer = true
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection heat transfer
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
  subsection fluid dynamics
    set verbosity      = quiet
    set tolerance      = 1e-8
    set max iterations = 5
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
  subsection heat transfer
    set verbosity         = quiet
    set method            = gmres
    set max iters         = 5000
    set relative residual = 1e-6
    set minimum residual  = 1e-11
    set preconditioner    = amg
  end
end
