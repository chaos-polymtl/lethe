# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method            = steady
  set number mesh adapt = 2
  set output frequency  = 0
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  set number of fluids = 1
  subsection fluid 0
    set kinematic viscosity = 1.0
  end
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = subdivided_hyper_rectangle
  set grid arguments     = 1, 1 : 0, 0 : 0.4, 1 : true
  set initial refinement = 2
end

#---------------------------------------------------
# Mortar
#---------------------------------------------------

subsection mortar
  set enable         = true
  set interface type = linear
  subsection mesh
    set type           = dealii
    set grid type      = subdivided_hyper_rectangle
    set grid arguments = 1, 1 : 0.4, 0 : 2, 1 : true
  end
  set rotor boundary id  = 4
  set stator boundary id = 1
  set verbosity          = verbose
end

#---------------------------------------------------
# FEM
#---------------------------------------------------

subsection FEM
  set enable bubble function velocity = false
  set velocity order                  = 2
  set pressure order                  = 2
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable    = true
  set verbosity = verbose
  subsection uvwp
    set Function expression = 0; x/2; 0
  end
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number                = 4
  set fix pressure constant = true
  subsection bc 0
    set id   = 0
    set type = noslip
  end
  subsection bc 1
    set id   = 5
    set type = function
    subsection u
      set Function expression = 0
    end
    subsection v
      set Function expression = 1
    end
  end
  subsection bc 2
    set id   = 2, 3, 6, 7
    set type = none
  end
  subsection bc 3
    set id   = 1, 4
    set type = none
  end
end

#---------------------------------------------------
# Mesh Adaptation Control
#---------------------------------------------------

subsection mesh adaptation
  set type = uniform
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection fluid dynamics
    set verbosity = quiet
    set tolerance = 1e-10
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set verbosity          = quiet
    set method             = gmres
    set max iters          = 500
    set max krylov vectors = 200
    set relative residual  = 1e-3
    set minimum residual   = 1e-12
    set preconditioner     = ilu
  end
end
