#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that box refinements at the initial condition are correctly
# generated in 3D with a manufactured solution.
# It also checks mesh scaling, translation and rotation in 3D.
# The quantities of interest are the number of cells and the velocity &
# pressure error values.
#-------------------------------------------------------------------------------

# Listing of Parameters
#----------------------

set dimension = 3

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = steady
  set output name      = multiple-box-refinement-3d
  set output frequency = 0
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = hyper_cube
  set grid arguments     = -1 : 1 : false
  set initial refinement = 3
end

#---------------------------------------------------
# Box Refinement
#---------------------------------------------------

subsection box refinement
  set number of refinement boxes = 3
  subsection box 0
    subsection mesh
      set type                   = dealii
      set grid type              = hyper_rectangle
      set grid arguments         = -0.25,-0.25,-0.5 : 0.25,0.25,0.5 : false
      set initial rotation axis  = 1, 0, 0
      set initial rotation angle = 0.78540 # pi/4
      set scale                  = 1.25
    end
    set additional refinement = 1
  end
  subsection box 1
    subsection mesh
      set type                = dealii
      set grid type           = hyper_cube
      set grid arguments      = -0.1 : 0.1 : false
      set initial translation = 0, 0, -0.5
    end
    set additional refinement = 2
  end
  subsection box 2
    subsection mesh
      set type               = dealii
      set grid type          = hyper_shell
      set grid arguments     = -0.8,.8,.8 : 0.4 : 0.6 : 0 : false
      set initial refinement = 2
    end
    set additional refinement = 1
  end
end

#---------------------------------------------------
# Multiphysics
#---------------------------------------------------

subsection multiphysics
  set fluid dynamics = true
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 1
  subsection bc 0
    set id   = 0
    set type = noslip
  end
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  subsection fluid 0
    set kinematic viscosity = 1.0
  end
end

#---------------------------------------------------
# Source term
#---------------------------------------------------

subsection source term
  subsection fluid dynamics
    set Function expression = 2*pi*pi*(-3*cos(2*pi*x)+2.)*sin(pi*y)*sin(pi*z)*cos(pi*y)*cos(pi*z)+pi*(2*(cos(pi* y)^2)-(cos(pi*z)^2))*(sin(pi*x)^3)*(sin(pi * y)^2)*(sin(pi * z)^2) * cos(pi*x); 2*pi*pi*(-3*cos(2*pi*y)+2) * sin(pi*x) * sin(pi*z) * cos(pi*x) * cos(pi*z)+pi*(2*(cos(pi* x)^2) -(cos(pi* z)^2)) * (sin(pi * x)^2) * (sin(pi * y)^3) * (sin(pi*z)^2) * cos(pi * y); 4*pi*pi*(3*cos(2*pi*z)-2) * sin(pi*x) * sin(pi*y) * cos(pi*x) * cos(pi*y)+2*pi*((cos(pi * x)^2) + (cos(pi * y)^2)) * (sin(pi * x)^2) * (sin(pi*y)^2) * (sin(pi*z)^3) * cos(pi*z);  0
  end
end

#---------------------------------------------------
# Analytical Solution
#---------------------------------------------------

subsection analytical solution
  set enable = true
  subsection uvwp
    set Function expression = sin(pi * x) * sin(pi * x) * cos(pi * y) * sin(pi * y) * cos(pi * z) * sin(pi * z);  cos(pi * x) * sin(pi * x) * sin(pi * y) * sin(pi * y) * cos(pi * z) * sin(pi * z);  -2 * cos(pi * x) * sin(pi * x) * cos(pi * y) * sin(pi * y) * sin(pi * z) * sin(pi * z);  0
  end
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection fluid dynamics
    set tolerance      = 1e-8
    set max iterations = 10
    set verbosity      = quiet
  end
end

#---------------------------------------------------
# Linear Solver Control
#---------------------------------------------------

subsection linear solver
  subsection fluid dynamics
    set method                                    = gmres
    set max iters                                 = 5000
    set relative residual                         = 1e-4
    set minimum residual                          = 1e-9
    set preconditioner                            = amg
    set amg preconditioner ilu fill               = 0
    set amg preconditioner ilu absolute tolerance = 1e-10
    set amg preconditioner ilu relative tolerance = 1.00
    set amg aggregation threshold                 = 1e-12
    set amg n cycles                              = 1
    set amg w cycles                              = false
    set amg smoother sweeps                       = 2
    set amg smoother overlap                      = 1
    set verbosity                                 = quiet
  end
end
