# Anisotropic-domain companion to multiperiodic_single_axis_collisions_2d.
#
# Identical minimal physics setup, but on a 2.0 x 0.5 rectangle instead
# of a unit square. The two periodic offset magnitudes (|offset_x| = 2.0,
# |offset_y| = 0.5) differ by a factor of 4. This catches any place in
# the periodic contact pipeline that accidentally assumes the periodic
# offsets share a magnitude or are commensurate with a single length
# scale (for example, a "nearest image" tie-break or a hard-coded
# threshold in cell-size units).
#
# As in the smoking-gun test, the y-periodic BC is registered first and
# the x-periodic BC second, so detecting this pair requires the pure
# +/- x offset that the buggy compute_combined_periodic_offsets omitted.

# Listing of Parameters
#----------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set time step        = 1e-5
  set time end         = 5e-3
  set log frequency    = 1000
  set output frequency = 0
end

#---------------------------------------------------
# Test
#---------------------------------------------------

subsection test
  set enable = true
end

#---------------------------------------------------
# Model parameters
#---------------------------------------------------

subsection model parameters
  subsection contact detection
    set contact detection method                = dynamic
    set dynamic contact search size coefficient = 0.8
    set neighborhood threshold                  = 1.3
  end
  set particle particle contact force method = hertz_mindlin_limit_overlap
  set particle wall contact force method     = nonlinear
  set integration method                     = velocity_verlet
  set rolling resistance torque method       = none
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection lagrangian physical properties
  set g                        = 0., 0.
  set number of particle types = 1
  subsection particle type 0
    set size distribution type            = uniform
    set diameter                          = 0.05
    set number of particles               = 2
    set density particles                 = 2000
    set young modulus particles           = 1e6
    set poisson ratio particles           = 0.3
    set restitution coefficient particles = 1.0
    set friction coefficient particles    = 0.0
    set rolling friction particles        = 0.0
  end
end

#---------------------------------------------------
# Insertion Info
#---------------------------------------------------

# Centers at x = 0.010 and x = 1.990 on the long (Lx = 2.0) axis;
# periodic distance = 0.020 < diameter 0.05 -> overlap of 0.030.
# Both at y = 0.250, far from the y-periodic boundary, so only the
# pure +/- x offset can produce a near-image.
subsection insertion info
  set insertion method    = list
  set insertion frequency = 1000000
  set list x              = 0.010, 1.990
  set list y              = 0.250, 0.250
  set list z              = 0.000, 0.000
  set list velocity x     = 0.000, 0.000
  set list velocity y     = 0.000, 0.000
  set list velocity z     = 0.000, 0.000
  set list omega x        = 0.000, 0.000
  set list omega y        = 0.000, 0.000
  set list omega z        = 0.000, 0.000
  set list diameters      = 0.050, 0.050
  set list temperatures   = 0.000, 0.000
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

# Refinement 3 on a 2.0 x 0.5 rectangle yields 8 x 8 cells of size
# 0.25 x 0.0625, both larger than the particle diameter.
subsection mesh
  set type                                = dealii
  set grid type                           = hyper_rectangle
  set grid arguments                      = 0.0, 0.0 : 2.0, 0.5 : true
  set initial refinement                  = 3
  set expand particle-wall contact search = false
end

#---------------------------------------------------
# Boundary conditions DEM
#---------------------------------------------------

# y-periodic registered first, x-periodic second so that the missing
# pure +/- offset under the bug is +/- x, which is the offset this test
# requires.
subsection DEM boundary conditions
  set number of boundary conditions = 2

  subsection boundary condition 0
    set type               = periodic
    set periodic id 0      = 3
    set periodic id 1      = 2
    set periodic direction = 1
  end

  subsection boundary condition 1
    set type               = periodic
    set periodic id 0      = 1
    set periodic id 1      = 0
    set periodic direction = 0
  end
end
