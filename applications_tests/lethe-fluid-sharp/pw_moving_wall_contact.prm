#-------------------------------------------------------------------------------
# DESCRIPTION:
# This test checks that Sharp-IB particle-wall contact uses translational DEM
# wall boundary conditions by applying tangential wall motion to a frictional
# particle-wall contact.
#-------------------------------------------------------------------------------

set dimension = 2

#---------------------------------------------------
# Simulation Control
#---------------------------------------------------

subsection simulation control
  set method           = bdf1   # Time integration
  set time step        = 0.0025 # Time step
  set time end         = 0.0025 # End time of simulation
  set output frequency = 0      # Frequency of simulation output
  set log precision    = 4
end

#---------------------------------------------------
# Physical Properties
#---------------------------------------------------

subsection physical properties
  subsection fluid 0
    set kinematic viscosity = 0.604166666666667
    set density             = 0.001
  end
end

#---------------------------------------------------
# Timer
#---------------------------------------------------

subsection timer
  set type = none
end

#---------------------------------------------------
# FEM
#---------------------------------------------------

subsection FEM
  set velocity order = 1
  set pressure order = 1
end

#---------------------------------------------------
# Mesh
#---------------------------------------------------

subsection mesh
  set type               = dealii
  set grid type          = subdivided_hyper_rectangle
  set grid arguments     = 5,8: 0,0 : 10,16 : true
  set initial refinement = 1
end

#---------------------------------------------------
# Boundary Conditions
#---------------------------------------------------

subsection boundary conditions
  set number = 4
  subsection bc 0
    set id   = 0
    set type = noslip
  end
  subsection bc 1
    set id   = 1
    set type = noslip
  end
  subsection bc 2
    set id   = 2
    set type = noslip
  end
  subsection bc 3
    set id   = 3
    set type = outlet
    set beta = 0
  end
end

#---------------------------------------------------
# DEM Boundary Conditions
#---------------------------------------------------

subsection DEM boundary conditions
  set number of boundary conditions = 1
  subsection boundary condition 0
    set boundary id = 2
    set type        = translational
    set speed x     = 10
    set speed y     = 0
    set speed z     = 0
  end
end

#---------------------------------------------------
# IB particles
#---------------------------------------------------

subsection particles
  set number of particles                     = 1
  set assemble Navier-Stokes inside particles = false

  subsection extrapolation function
    set stencil order = 6
  end

  subsection local mesh refinement
    set initial refinement                = 2
    set refine mesh inside radius factor  = 0.5
    set refine mesh outside radius factor = 1.5
  end

  subsection DEM
    set enable lubrication force = false
    subsection gravity
      set Function expression = 0;0
    end
    subsection wall physical properties
      set wall friction coefficient = 0.5
    end
  end

  subsection particle info 0
    set integrate motion = true
    subsection position
      set Function expression = 5;0.72
    end
    subsection velocity
      set Function expression = 0;0
    end
    subsection omega
      set Function expression = 0;0;0
    end
    set pressure location = 0.00001; 0.00001
    set type              = sphere
    set shape arguments   = 0.75

    subsection physical properties
      set density              = 0.0011
      set friction coefficient = 0.5
    end
  end
end

#---------------------------------------------------
# Mesh Adaptation Control
#---------------------------------------------------

subsection mesh adaptation
  set fraction coarsening  = 0.4
  set fraction refinement  = 0.05
  set fraction type        = number
  set frequency            = 1
  set max number elements  = 75000
  set max refinement level = 3
  set min refinement level = 0
  set type                 = adaptive
  set error estimator      = kelly
  set variable             = velocity
end

#---------------------------------------------------
# Initial condition
#---------------------------------------------------

subsection initial conditions
  set type                = nodal
  set kinematic viscosity = 0.05
end

#---------------------------------------------------
# Non-Linear Solver Control
#---------------------------------------------------

subsection non-linear solver
  subsection fluid dynamics
    set tolerance             = 1e-8
    set max iterations        = 5
    set verbosity             = quiet
    set force rhs calculation = true
  end
end

#---------------------------------------------------
# Forces
#---------------------------------------------------

subsection forces
  set verbosity = verbose
end

#---------------------------------------------------
# Restart
#---------------------------------------------------

subsection restart
  set checkpoint = false
  set filename   = check_point
  set frequency  = 1
  set restart    = false
end
