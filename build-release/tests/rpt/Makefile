solid_angle.s: solid_angle.cc.s
.PHONY : solid_angle.s

# target to generate assembly for a file
solid_angle.cc.s:
	cd /opt/lethe/build-release && $(MAKE) $(MAKESILENT) -f tests/rpt/CMakeFiles/rpt.solid_angle.release.dir/build.make tests/rpt/CMakeFiles/rpt.solid_angle.release.dir/solid_angle.cc.s
.PHONY : solid_angle.cc.s

