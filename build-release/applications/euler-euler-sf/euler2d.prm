    # k_A1 parameter for linear conductivity model
    set k_A1                           = 0

    # Kinematic viscosity for the fluid corresponding to Phase = 0
    set kinematic viscosity            = 1

    # Rheological model Choices are
    # <newtonian|power-law|carreau|phase_change>.
    set rheological model              = newtonian

    # Specific heat for the fluid corresponding to Phase = 0
    set specific heat                  = 1

    # Model used for the calculation of the specific heatChoices are
    # <constant|phase_change>.
    set specific heat model            = constant

    # Thermal conductivity for the fluid corresponding to Phase = 0
    set thermal conductivity           = 1

    # Model used for the calculation of the thermal conductivityChoices are
    # <constant|linear|phase_change>.
    set thermal conductivity model     = constant

    # Thermal expansion coefficient for the fluid corresponding to Phase = 0
    set thermal expansion              = 1

    # Model used for the calculation of the thermal expansion
    # coefficientChoices are <constant|phase_change>.
    set thermal expansion model        = constant

    # Tracer diffusivity for the fluid corresponding to Phase = 0
    set tracer diffusivity             = 0

    # Model used for the calculation of the tracer diffusivityChoices are
    # <constant|immersed solid tanh>.
    set tracer diffusivity model       = constant

    # Tracer reaction constant for the fluid corresponding to Phase = 0
    set tracer reaction constant       = 0

    # Model used for the calculation of the tracer reaction constantChoices
    # are <none|constant|immersed solid tanh>.
    set tracer reaction constant model = constant

    # Tracer reaction order for the fluid corresponding to Phase = 0
    set tracer reaction order          = 1


    subsection immersed solid tanh
      # Thickness to be used with the tanh function
      set thickness                        = 1.0

      # Tracer diffusivity inside the immersed solid
      set tracer diffusivity inside        = 1.0

      # Tracer diffusivity outside the immersed solid
      set tracer diffusivity outside       = 1.0

      # Tracer reaction constant inside the immersed solid
      set tracer reaction constant inside  = 0.0

      # Tracer reaction constant outside the immersed solid
      set tracer reaction constant outside = 0.0
    end

    subsection isothermal_ideal_gas
      # Specific gas constant in SI units for isothermal ideal gas equation of
      # state in density calculation
      set R           = 287.05

      # Absolute temperature of the gas in kelvin (K) for isothermal ideal gas
      # equation of state in density calculation
      set T           = 293.15

      # Reference density of the gas in SI units for isothermal ideal gas
      # equation of state in density calculation
      set density_ref = 1.2
    end

    subsection non newtonian
      subsection carreau
        # Carreau parameter
        set a             = 2.0

        # Relaxation time
        set lambda        = 1.0

        # Power parameter
        set n             = 0.5

        # Kinematic viscosity at rest
        set viscosity_0   = 1.0

        # Kinematic viscosity for an infinite shear rate
        set viscosity_inf = 1.0
      end

      subsection power-law
        # Fluid consistency index
        set K              = 1.0

        # Flow behavior index
        set n              = 0.5

        # Minimal shear rate magnitude
        set shear rate min = 0.001
      end

    end

    subsection phase change
      # Darcy penalty of the liquid phase
      set Darcy penalty liquid        = 0

      # Darcy penalty of the solid phase
      set Darcy penalty solid         = 0

      # Enthalpy of the phase change
      set latent enthalpy             = 1

      # Temperature of the liquidus
      set liquidus temperature        = 1

      # Temperature of the solidus
      set solidus temperature         = 0

      # Specific heat of the liquid phase
      set specific heat liquid        = 1

      # Specific heat of the solid phase
      set specific heat solid         = 1

      # Thermal conductivity of the liquid phase
      set thermal conductivity liquid = 1

      # Thermal conductivity of the solid phase
      set thermal conductivity solid  = 1

      # Thermal expansion coefficient of the liquid phase
      set thermal expansion liquid    = 1

      # Thermal expansion coefficient of the solid phase
      set thermal expansion solid     = 0

      # Kinematic viscosity of the liquid phase
      set viscosity liquid            = 1

      # Kinematic viscosity of the solid phase
      set viscosity solid             = 1
    end

  end

end


subsection post-processing
  # File output apparent viscosity
  set apparent viscosity name                            = apparent_viscosity

  # Name of barycenter information output file in VOF or Cahn-Hilliard
  # simulations
  set barycenter name                                    = barycenter_information

  # Enable calculation of apparent viscosity
  set calculate apparent viscosity                       = false

  # Enable calculation of time average temperature and time average heat flux
  set calculate average temperature and heat flux        = false

  # Enable calculation of average velocities.
  set calculate average velocities                       = false

  # Enable calculation of the barycenter location and velocity of fluid 1 in
  # VOF and Cahn-Hilliard simulations.
  set calculate barycenter                               = false

  # Enable calculation of total enstrophy. The total enstrophy is calculated
  # from the volumetric integral of the enstrophy over the domain.
  set calculate enstrophy                                = false

  # Enable calculation of flow rate at boundaries.
  set calculate flow rate                                = false

  # Enable calculation of heat flux.
  set calculate heat flux                                = false

  # Enable calculation of total kinetic energy. The total kinetic energy is
  # calculated from the volumetric integral of the kinetic energy over the
  # domain.
  set calculate kinetic energy                           = false

  # Enable calculation of the liquid fraction. The liquid fraction is
  # calculated from the volume integral of the liquid fraction divided by the
  # volume of the domain.
  set calculate liquid fraction                          = false

  # Enable calculation of the mass and momentum of both fluids in VOF
  # simulations.
  set calculate mass conservation                        = true

  # Enable calculation of phase energies, including: total energy, bulk
  # energy, and interface energy
  set calculate phase energy                             = false

  # Enable calculation of phase statistics: maximum, minimum, average and
  # integral over the domain (Cahn-Hilliard).
  set calculate phase statistics                         = false

  # Enable calculation of total volume each phases in cfd-dem simulation,
  # including: total volume of fluid, and total volume of particles
  set calculate phase volumes                            = false

  # Enable calculation of pressure drop between two boundaries.
  set calculate pressure drop                            = false

  # Enable calculation of the pressure power. The pressure power is calculated
  # from the volumetric integral of u.grad(p) over the domain.
  set calculate pressure power                           = false

  # Enable calculation of temperature statistics.
  set calculate temperature statistics                   = false

  # Enable calculation of tracer flow rate at boundaries.
  set calculate tracer flow rate                         = false

  # Enable calculation of tracer statistics.
  set calculate tracer statistics                        = false

  # Enable calculation of the viscous dissipation. The viscous dissipation is
  # calculated from the volumetric integral of grad(u).tau over the domain.
  set calculate viscous dissipation                      = false

  # File name output for the convective flux
  set convective flux name                               = convective_flux

  # File output enstrophy
  set enstrophy name                                     = enstrophy

  # File output volumetric flux
  set flow rate name                                     = flow_rate

  # State whether force chains visualization should be performed.
  set force chains                                       = false

  # File name output for the heat flux
  set heat flux name                                     = heat_flux

  # Initial time to start calculations for average temperature
  set initial time for average temperature and heat flux = 0.0

  # Initial time to start calculations for average velocities
  set initial time for average velocity                  = 0.0

  # Inlet boundary ID for pressure drop calculation
  set inlet boundary id                                  = 0

  # File output kinetic energy
  set kinetic energy name                                = kinetic_energy

  # State whether lagrangian post-processing should be performed.
  set lagrangian post-processing                         = false

  # File name output liquid fraction
  set liquid fraction name                               = liquid_fraction

  # Name of mass conservation output file in VOF simulations
  set mass conservation name                             = mass_conservation_information

  # File name output for the convective flux
  set nitsche flux name                                  = nitsche_heat_flux

  # Outlet boundary ID for pressure drop calculation
  set outlet boundary id                                 = 1

  # Output frequency
  set output frequency                                   = 1

  # Name of energy output file in Cahn-Hilliard simulations. The file is
  # stored in the output folder specified in the simulation control
  # subsection
  set phase energy name                                  = phase_energy

  # File name output phase statistics (Cahn-Hilliard)
  set phase statistics name                              = phase_statistics

  # Name of phases volume output file in cfd-dem simulations. The file is
  # stored in the output folder specified in the simulation control
  # subsection
  set phase volumes name                                 = phase_volumes

  # Fluid domain used for thermal postprocesses in the heat equation <fluid
  # 0|fluid 1|both>
  set postprocessed fluid                                = both

  # File output pressure drop
  set pressure drop name                                 = pressure_drop

  # File output pressure power
  set pressure power name                                = pressure_power

  # Enable smoothing postprocessed vectors and scalars.
  set smoothed output fields                             = false

  # File name output temperature statistics
  set temperature statistics name                        = temperature_statistics

  # Output file name for tracer flow rate
  set tracer flow rate name                              = tracer_flow_rate

  # File name output tracer statistics
  set tracer statistics name                             = tracer_statistics

  # State whether from the post-processing values should be printed Choices
  # are <quiet|verbose>.
  set verbosity                                          = quiet

  # File output viscous dissipation
  set viscous dissipation name                           = viscous_dissipation
end


subsection restart
  # Enable checkpointing. Checkpointing creates a restartpoint from which the
  # simulation can be restarted from.
  set checkpoint = false

  # Prefix for the filename of checkpoints
  set filename   = restart

  # Frequency for checkpointing
  set frequency  = 1

  # Frequency for checkpointing
  set restart    = false
end


subsection simulation control
  # Adaptative time-stepping <true|false>
  set adapt                             = false

  # Adaptative time step scaling
  set adaptative time step scaling      = 1.1

  # The kind of method used to startup high order bdf methods Choices are
  # <multiple step bdf|initial solution>.
  set bdf startup method                = multiple step bdf

  # Maximal number of vtu output files
  set group files                       = 1

  # log frequency
  set log frequency                     = 1

  # Display precision when writing to log
  set log precision                     = 6

  # Maximum CFL value
  set max cfl                           = 1

  # Maximum time step value
  set max time step                     = 1e6

  # The kind of solver for the linear system. Choices are
  # <steady|steady_bdf|bdf1|bdf2|bdf3>.
  set method                            = bdf1

  # Number of mesh adaptation (for steady simulations)
  set number mesh adapt                 = 0

  # Output the boundaries of the domain along with their ID
  set output boundaries                 = false

  # The control for the output of the simulation resultsResults can be either
  # outputted at constant iteration frequency or at constant time
  set output control                    = iteration

  # Output iteration frequency
  set output frequency                  = 1

  # File output prefix
  set output name                       = out

  # File output prefix
  set output path                       = ./

  # Output time frequency
  set output time frequency             = -1

  # Output files for a desired time interval
  set output time interval              = 0, 1.7976931348623157e308

  # List of specific output times separated with a comma
  set output times                      = -1

  # Scaling factor used in the iterations necessary to start-up the BDF
  # schemes.
  set startup time scaling              = 0.4

  # Tolerance at which the simulation is stopped
  set stop tolerance                    = 1e-10

  # Subdivision of mesh cell in postprocessing
  set subdivision                       = 1

  # Time step value
  set time end                          = 2

  # Time step value
  set time step                         = 1e-3

  # Ensures that the correct time step is kept when using adaptive time step
  # simulations
  set time step independent of end time = true
end


subsection solid objects
  subsection solid surfaces
    # Number of solid surfaces
    set number of solids = 0


    subsection solid object 0
      # Solid object center of rotation
      set center of rotation  = 0., 0.

      # Controls the generation of output files
      set output solid object = true


      subsection angular velocity
        # Sometimes it is convenient to use symbolic constants in the
        # expression that describes the function, rather than having to use
        # its numeric value everywhere the constant appears. These values can
        # be defined using this parameter, in the form `var1=value1,
        # var2=value2, ...'.
        # 
        # A typical example would be to set this runtime parameter to
        # `pi=3.1415926536' and then use `pi' in the expression of the actual
        # formula. (That said, for convenience this class actually defines
        # both `pi' and `Pi' by default, but you get the idea.)
        set Function constants  = 

        # The formula that denotes the function you want to evaluate for
        # particular values of the independent variables. This expression may
        # contain any of the usual operations such as addition or
        # multiplication, as well as all of the common functions such as `sin'
        # or `cos'. In addition, it may contain expressions like `if(x>0, 1,
        # -1)' where the expression evaluates to the second argument if the
        # first argument is true, and to the third argument otherwise. For a
        # full overview of possible expressions accepted see the documentation
        # of the muparser library at http://muparser.beltoforion.de/.
        # 
        # If the function you are describing represents a vector-valued
        # function with multiple components, then separate the expressions for
        # individual components by a semicolon.
        set Function expression = 0; 0; 0

        # The names of the variables as they will be used in the function,
        # separated by commas. By default, the names of variables at which the
        # function will be evaluated are `x' (in 1d), `x,y' (in 2d) or `x,y,z'
        # (in 3d) for spatial coordinates and `t' for time. You can then use
        # these variable names in your function expression and they will be
        # replaced by the values of these variables at which the function is
        # currently evaluated. However, you can also choose a different set of
        # names for the independent variables at which to evaluate your
        # function expression. For example, if you work in spherical
        # coordinates, you may wish to set this input parameter to
        # `r,phi,theta,t' and then use these variable names in your function
        # expression.
        set Variable names      = x,y,t
      end

      subsection mesh
        # Boundary ids of the boundaries to be initially refined
        set boundaries refined                  = 

        # Enables checking the input grid for diamond-shaped cells.
        set check diamond cells                 = false

        # Enable initial refinement until target size is reached.
        set enable target size                  = false

        # Enables adding the boundary neighbor cells of boundary cells to
        # theparticle-wall contact search list. This feature should only be
        # activated in geometries with concave boundaries. (For example, for
        # particles flow inside a cylinder or sphere). In geometries with
        # convex boundaries, this feature MUST NOT be activated
        set expand particle-wall contact search = false

        # GMSH file name
        set file name                           = none
        set grid arguments                      = -1 : 1 : false
        set grid type                           = hyper_cube

        # Initial refinement of the mesh at the boundaries specified by the
        # user
        set initial boundary refinement         = 0

        # Initial refinement of the mesh
        set initial refinement                  = 0

        # Angle of rotation of the mesh at initialization around the axis in
