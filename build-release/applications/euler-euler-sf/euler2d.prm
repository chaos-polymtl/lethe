subsection laser parameters
  # Laser absorptivity
  set absorptivity         = 0.5

  # Laser beam orientation Choices are <x+|x-|y+|y-|z+|z->.
  set beam orientation     = z-

  # Laser beam radius
  set beam radius          = 0.0

  # Angle of rotation in rad of the beam axis with respect to the axis defined
  # by the beam orientation parameter
  set beam rotation angle  = 0.0

  # Axis around which the laser beam is rotated, only used in 3D
  set beam rotation axis   = 0.0, 0.0, 1.0

  # Concentration factor
  set concentration factor = 2.0

  # Activate laser
  set enable               = false

  # End time of laser
  set end time             = 1.0

  # Penetration depth
  set penetration depth    = 1.0

  # Laser power
  set power                = 0.0

  # Start time of laser
  set start time           = 0.0

  # Type of laser model used.Choices are
  # <exponential_decay|gaussian_heat_flux_vof_interface|uniform_heat_flux_vof_interface>.
  set type                 = gaussian_heat_flux_vof_interface


  subsection free surface radiation
    # Stefan-Boltzmann constant
    set Stefan-Boltzmann constant = 5.6703e-8

    # Temperature (Double) of environment for radiation term at the free
    # surface (air/metal interface)
    set Tinf                      = 0.0

    # Emissivity of the free surface (air/metal interface)
    set emissivity                = 0.6

    # Enable radiation at the free surface (air/metal interface) <true|false>
    set enable                    = false
  end

  subsection path
    # Sometimes it is convenient to use symbolic constants in the expression
