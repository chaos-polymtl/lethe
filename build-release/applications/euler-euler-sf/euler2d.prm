  end

  subsection ramp
    subsection kinematic viscosity
      # Coefficient used for kinematic viscosity-spacing.
      set alpha                       = 0.5

      # First kinematic viscosity value with which to start the initial
      # condition
      set initial kinematic viscosity = 1.0

      # Number of iterations used in the ramp before reaching the final
      # kinematic viscosity value
      set iterations                  = 0
    end

    subsection n
