end


subsection velocity source
  # Darcy-like permeability termChoices are <none|phase_change>.
  set Darcy type          = none

  # X component of the angular velocity vector of the frame of reference
  set omega_x             = 0 

  # Y component of the angular velocity vector of the frame of reference
  set omega_y             = 0 

  # Z component of the angular velocity vector of the frame of reference
  set omega_z             = 0 

  # Rotating frame velocity-dependent source termsChoices are <none|srf>. The
  # srf standsfor single rotating frame and addsthe coriolis and the
  # centrifugal force to the Navier-Stokes equations
  set rotating frame type = none
end


subsection void fraction
  # File output dem prefix
  set dem file name                = dem

  # The smoothing length for void fraction L2 projection
  set l2 smoothing length          = 0.001

  # Choose the method for the calculation of the void fraction
  set mode                         = function

  # Number of quadrature points per cell used in the QCM void fraction scheme
  set n quadrature points          = 0

  # The refinement factor used to calculate the number of pseudo-particles in
  # the satellite point method
  set particle refinement factor   = 0

  # The diameter of the reference sphere for QCM void fraction scheme
  set qcm sphere diameter          = 0

  # Specify whether the virtual sphere has the same volume as the mesh
  # element
  set qcm sphere equal cell volume = false

  # Choose which quadrature rule to follow when distributing quadrature points
  # for the QCM void fraction scheme
  set quadrature rule              = gauss

  # Define particles using a DEM simulation results file.
  set read dem                     = false


