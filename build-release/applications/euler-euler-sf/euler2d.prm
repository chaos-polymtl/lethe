subsection boundary forces
  # Enable calculation of forces
  set calculation      = false

  # File output force prefix
  set filename         = force

  # Output frequency
  set output frequency = 1

  # State whether output from solver runs should be printed. Choices are
  # <quiet|verbose>.
  set verbosity        = verbose


  subsection center of mass coordinate
    # X coordinate of center of mass
    set x = 0

    # Y coordinate of center of mass
    set y = 0

    # Z coordinate of center of mass
    set z = 0
  end

end


subsection box refinement
  # Initial refinement of the principal mesh
  set initial refinement = 0


  subsection mesh
    # Boundary ids of the boundaries to be initially refined
    set boundaries refined                  = 

    # Enables checking the input grid for diamond-shaped cells.
    set check diamond cells                 = false

    # Enable initial refinement until target size is reached.
    set enable target size                  = false

    # Enables adding the boundary neighbor cells of boundary cells to
    # theparticle-wall contact search list. This feature should only be
    # activated in geometries with concave boundaries. (For example, for
    # particles flow inside a cylinder or sphere). In geometries with convex
    # boundaries, this feature MUST NOT be activated
    set expand particle-wall contact search = false

    # GMSH file name
    set file name                           = none
    set grid arguments                      = -1 : 1 : false
    set grid type                           = hyper_cube

    # Initial refinement of the mesh at the boundaries specified by the user
    set initial boundary refinement         = 0

    # Initial refinement of the mesh
    set initial refinement                  = 0

    # Angle of rotation of the mesh at initialization around the axis in
    # radian
    set initial rotation angle              = 0

    # Component of the desired rotation of the mesh at initialization
    set initial rotation axis               = 1, 0, 0

    # Component of the desired translation of the mesh at initialization
    set initial translation                 = 0, 0, 0

    # Scaling factor used for the mesh.
    set scale                               = 1

    # Indicates that the mesh used is a mesh made of only simplex elements.
    set simplex                             = false

    # Target size of the initial refinement
    set target size                         = 1

    # Type of mesh Choices are <gmsh|dealii|periodic_hills|cylinder>.
    set type                                = dealii
  end

end


subsection cahn hilliard
  # Smoothing coefficient for the chemical potential in the Cahn-Hilliard
  # equations.
  set potential smoothing coefficient = 1


  subsection epsilon
    # Parameter linked to the interface thickness. Should always be bigger
    # than the characteristic size of the smallest element
    set value     = 1.0

    # Epsilon is either set to two times the characteristic length (automatic)
    # of the element or user defined on all the domain (manual)
    set method    = automatic

    # Display the value of epsilon for each time iteration if set to verbose
    set verbosity = quiet
  end

  subsection phase filtration
    # This parameter appears in the tanh filter function. It influence the
    # thickness and the shape of the interface. For higher values of beta, a
    # thinner and 'sharper/pixelated' interface will be seen.
    set beta      = 20

    # CahnHilliard phase filtration type, if <none> is selected, the phase
    # won't be filteredif <clip> is selected, the phase order values above 1
    # (respectively below -1) will be brought back to 1 (respectively -1)if
    # <tanh> is selected, the filtered phase will be a result of the following
    # function: \alpha_f = \tanh(\beta\alpha); where beta is a parameter
    # influencing the interface thickness that must be defined
    set type      = none

    # States whether the filtered data should be printed Choices are
    # <quiet|verbose>.
    set verbosity = quiet
  end

end


subsection cfd-dem
  # Choose whether or not to apply buoyancy force
  set buoyancy force                = true

  # dem-cfd coupling frequency
  set coupling frequency            = 100

  # Choose whether or not to apply drag force
  set drag force                    = true

  # The drag model used to determine the drag coefficient
  set drag model                    = difelice

  # Choose whether or not to apply grad_div stabilization
  set grad div                      = true

  # Constant cs for the calculation of the grad-div stabilization (gamma =
  # kinematic_viscosity + cs * velocity)
  set grad-div length scale         = 1

  # Choose whether or not to use implicit or explicit stabilization
  set implicit stabilization        = true

  # Choose whether the void fraction is the one of the cell or the one
  # interpolated at the particle position.
  set interpolated void fraction    = true

  # Choose whether or not to apply Magnus lift force
  set magnus lift force             = false

  # Outputs statistics about the particles such as their total kinetic energy,
  # angular momentum, etc.
  set particle statistics           = true

  # Choose whether or not to apply pressure force
  set pressure force                = true

  # Choose whether or not to apply rotational viscous torque on particles
  set rotational viscous torque     = false

  # Choose whether or not to apply Saffman-Mei lift force
  set saffman lift force            = false

  # Choose whether or not to apply shear force
  set shear force                   = true

  # The volume averaged Navier Stokes model to be solved.
  set vans model                    = modelA

  # Choose whether or not to implement d(epsilon)/dt
  set void fraction time derivative = false

  # Choose whether or not to apply vortical viscous torque on particles
  set vortical viscous torque       = false
end


subsection constrain stasis
  # Enable/disable (true/false) the solid domain constraining feature.
  set enable                               = false

  # Enable/disable (true/false) the definition of a plane for geometrical
  # restrictions on the domain where the solid domain constraining feature
  # is applied.
  set enable domain restriction with plane = false

  # Number of solid constraints (maximum of 1 per fluid).
  set number of constraints                = 0

  # Domain restriction plane outward pointing normal vector.
  set restriction plane normal vector      = 0., 0.

  # Domain restriction plane point coordinates.
  set restriction plane point              = 0., 0.


  subsection constraint 0
    # Identifier of the fluid material that is constrained.
    set fluid id                 = 0

    # Maximum temperature value of the fluid for it be considered as a solid.
    set max temperature          = 0

    # Minimum temperature value of the fluid for it be considered as a solid.
    set min temperature          = -999

    # Absolute filtered phase fraction tolerance used in conjunction with VOF
    # simulations to select the cells on which the constraint is applied.
    set phase fraction tolerance = 1e-4
  end

  subsection constraint 1
    # Identifier of the fluid material that is constrained.
    set fluid id                 = 0

    # Maximum temperature value of the fluid for it be considered as a solid.
    set max temperature          = 0

    # Minimum temperature value of the fluid for it be considered as a solid.
    set min temperature          = -999

    # Absolute filtered phase fraction tolerance used in conjunction with VOF
    # simulations to select the cells on which the constraint is applied.
    set phase fraction tolerance = 1e-4
  end

end


subsection dimensionality
  # Length scale. The default value assumed is meters. If the simulation is
  # carried out in centimeters, a length of 0.01 should be specified. If the
  # simulation is carried out in kilometers, a length of 1000 should be
  # specified.
  set length      = 1

  # Mass scale. The default value assumed is kilograms. If the simulation is
  # carried out in grams, a mass of 0.001 should be specified.
  set mass        = 1

  # Temperature scale. The default value assumed is Kelvin. If the simulation
  # is carried out in kiloKelvin, a temperature of 1000 should be specified.
  set temperature = 1

  # Time scale. The default value assumed is seconds. If the simulation is
  # carried out in milliseconds, a time of 0.001 should be specified.
  set time        = 1
end


subsection evaporation
  # Ambient gas density in M*L^-3
  set ambient gas density         = 1.0

  # Pressure of the ambient gas in M*L^-1*T^-2
  set ambient pressure            = 101325

  # Boiling temperature in Theta
  set boiling temperature         = 1.0

  # Enable the evaporative cooling at the free surface (gas/liquid interface)
  # in the energy equation <true|false>
  set enable evaporative cooling  = false

  # Enable the recoil pressure due to evaporation at the free surface
  # (gas/liquid interface) in the momentum equation <true|false>
  set enable recoil pressure      = false

  # Evaporation coefficient corresponding to the ratio between the net mass
  # flux (evaporation-condensation) and the mass flux of evaporation
  set evaporation coefficient     = 0.82

  # Latent heat of evaporation in L^2*T^-2
  set evaporation latent heat     = 0.0

  # Evaporation mass flux used if the constant evaporation model is selected
  # in M*L^-2*T^-1
  set evaporation mass flux       = 0.0

  # Model used for the calculation of the evaporative mass fluxChoices are
  # <constant|temperature_dependent>.
  set evaporation mass flux model = constant

  # Liquid density in M*L^-3
  set liquid density              = 10.0

  # Molar mass of the material in M*N^-1
  set molar mass                  = 1.0

  # Recoil pressure coefficient corresponding to the factor applied to the
  # saturation pressure to compute the recoil pressure in an out of
  # equilibrium evaportation
  set recoil pressure coefficient = 0.56

  # Universal gas constant in M*L^2*T^-2*Theta^-1*N^-1
  set universal gas constant      = 8.3145
end


subsection floating grid
  # End time
  set end time   = 0.

  # Start time
  set start time = 0.


  subsection grid motion
    # grid rotational axis
    set grid rotational axis          = 0

    # grid rotational speed
    set grid rotational speed         = 0

    # grid translational velocity x
    set grid translational velocity x = 0

    # grid translational velocity y
    set grid translational velocity y = 0

    # grid translational velocity z
    set grid translational velocity z = 0

    # Choosing grid motion type. Choices are
    # <none|translational|rotational|translational_rotational>.
    set motion type                   = none
  end

  subsection mesh
    # Boundary ids of the boundaries to be initially refined
    set boundaries refined                  = 

    # Enables checking the input grid for diamond-shaped cells.
    set check diamond cells                 = false

    # Enable initial refinement until target size is reached.
    set enable target size                  = false

    # Enables adding the boundary neighbor cells of boundary cells to
    # theparticle-wall contact search list. This feature should only be
    # activated in geometries with concave boundaries. (For example, for
    # particles flow inside a cylinder or sphere). In geometries with convex
    # boundaries, this feature MUST NOT be activated
    set expand particle-wall contact search = false

    # GMSH file name
    set file name                           = none
    set grid arguments                      = -1 : 1 : false
    set grid type                           = hyper_cube

    # Initial refinement of the mesh at the boundaries specified by the user
    set initial boundary refinement         = 0

    # Initial refinement of the mesh
    set initial refinement                  = 0

    # Angle of rotation of the mesh at initialization around the axis in
    # radian
    set initial rotation angle              = 0

    # Component of the desired rotation of the mesh at initialization
    set initial rotation axis               = 1, 0, 0

    # Component of the desired translation of the mesh at initialization
    set initial translation                 = 0, 0, 0

    # Scaling factor used for the mesh.
    set scale                               = 1

    # Indicates that the mesh used is a mesh made of only simplex elements.
    set simplex                             = false

    # Target size of the initial refinement
    set target size                         = 1

    # Type of mesh Choices are <gmsh|dealii|periodic_hills|cylinder>.
    set type                                = dealii
  end

end


