subsection manifolds
  # Number of boundary conditions
  set number = 0


  subsection manifold 0
    # IGES file name
    set cad file          = none

    # Central axis describing the cylindrical manifold
    set direction vector  = 0,1,0

    # Mesh id for boundary conditions
    set id                = 00

    # Point coordinates describing the spherical or cylindrical manifold
    set point coordinates = 0,0,0

    # Type of manifold descriptionChoices are
    # <none|spherical|cylindrical|iges>.
    set type              = none
  end

end


subsection mesh
  # Boundary ids of the boundaries to be initially refined
  set boundaries refined                  = 

  # Enables checking the input grid for diamond-shaped cells.
  set check diamond cells                 = false

  # Enable initial refinement until target size is reached.
  set enable target size                  = false

  # Enables adding the boundary neighbor cells of boundary cells to
  # theparticle-wall contact search list. This feature should only be
  # activated in geometries with concave boundaries. (For example, for
  # particles flow inside a cylinder or sphere). In geometries with convex
  # boundaries, this feature MUST NOT be activated
  set expand particle-wall contact search = false

  # GMSH file name
  set file name                           = none
  set grid arguments                      = -1 : 1 : true
  set grid type                           = hyper_cube

  # Initial refinement of the mesh at the boundaries specified by the user
  set initial boundary refinement         = 0

  # Initial refinement of the mesh
  set initial refinement                  = 5

  # Angle of rotation of the mesh at initialization around the axis in radian
  set initial rotation angle              = 0

  # Component of the desired rotation of the mesh at initialization
  set initial rotation axis               = 1, 0, 0

  # Component of the desired translation of the mesh at initialization
  set initial translation                 = 0, 0, 0

  # Scaling factor used for the mesh.
  set scale                               = 1

  # Indicates that the mesh used is a mesh made of only simplex elements.
  set simplex                             = false

  # Target size of the initial refinement
  set target size                         = 1

  # Type of mesh Choices are <gmsh|dealii|periodic_hills|cylinder>.
  set type                                = dealii
end


subsection mesh adaptation
  # Boundary ids of the boundaries to be fixed
  set boundaries fixed           = 

  # Enable fix boundary refinement
  set fix boundary refinement    = false

  # Fraction of coarsened elementsFor multi-variables refinement, separate the
  # different fractions with a comma (ex/ 'set fraction coarsening =
  # 0.05,0.05')
  set fraction coarsening        = 0.05

  # Fraction of refined elementsFor multi-variables refinement, separate the
  # different fractions with a comma (ex/ 'set fraction refinement =
  # 0.1,0.1')
  set fraction refinement        = 0.1

  # How the fraction of refinement/coarsening are interpretedChoices are
  # <number|fraction>.
  set fraction type              = number

  # Frequency of the mesh refinement
  set frequency                  = 1

  # Number of pre-solve adaptive mesh refinement steps
  set initial refinement steps   = 0

  # Maximum number of elements
  set max number elements        = 100000000

  # Maximum refinement level
  set max refinement level       = 10

  # Fraction of refined elementsEnable a controller that will target a
  # specific number of elements in the mesh equal to the maximum number of
  # elements
  set mesh refinement controller = false

  # Minimum refinement level
  set min refinement level       = 0

  # Type of mesh adaptationChoices are <none|uniform|kelly>.
  set type                       = none

  # Variable(s) for kelly estimationChoices are
  # <velocity|pressure|phase|temperature|phase_cahn_hilliard|chemical_potential_cahn_hilliard|tracer>.For
  # multi-variables refinement, separate the different variables with a comma
  # (ex/ 'set variables = velocity,temperature')
  set variable                   = velocity
end


subsection model parameters
  # Cut-off threshold above which the Van der Waal forces are ignored for the
  # DMT model relative to the pull-off force
  set dmt cut-off threshold                  = 0.1

  # Model parameter for the EPSD rolling resistance model.
  set f coefficient                          = 0.

  # Choosing integration methodChoices are <velocity_verlet|explicit_euler>.
  set integration method                     = velocity_verlet

  # Choosing particle-particle contact force modelChoices are
  # <linear|hertz_mindlin_limit_force|hertz_mindlin_limit_overlap|hertz|hertz_JKR|DMT>.
  set particle particle contact force method = hertz_mindlin_limit_overlap

  # Choosing particle-wall contact force modelChoices are
  # <linear|nonlinear|JKR|DMT>.
  set particle wall contact force method     = nonlinear

  # Choosing rolling resistance torque modelChoices are
  # <no_resistance|constant_resistance|viscous_resistance|epsd_resistance>.
  set rolling resistance torque method       = constant_resistance

  # Choosing solver typeChoices are <dem|cfd_dem|dem_mp>.
  set solver type                            = dem


  subsection adaptive sparse contacts
    # Enable the dynamic search for sparse particle contactsChoices are
    # <true|false>.
    set enable adaptive sparse contacts = false

    # Enable the advection of particles with hydrodynamic forcesChoices are
    # <true|false>.
    set enable particle advection       = false

    # Minimum granular temperature where particle contacts are considered
    set granular temperature threshold  = 1e-4

    # Maximum solid fraction where particle contacts are considered no matter
    # the granular temperature
    set solid fraction threshold        = 0.4
  end

  subsection contact detection
    # Choosing contact detection methodChoices are <constant|dynamic>.
    set contact detection method                = dynamic

    # Security coefficient for dynamic contact detection
    set dynamic contact search size coefficient = 0.8

    # Particle-particle contact list
    set frequency                               = 1

    # Contact search zone diameter to particle diameter ratio
    set neighborhood threshold                  = 1.3
  end

  subsection load balancing
    # Factor applied on the particle weight in load balancing if the cell is
    # active
    set active weight factor    = 1.0

    # Checking frequency for dynamic load-balancing
    set dynamic check frequency = 10000

    # Frequency at which the triangulation is repartitioned and load is
    # balanced for frequent load-balancing
    set frequency               = 100000

    # Factor applied on the particle weight in load balancing if the cell is
    # inactive
    set inactive weight factor  = 1.0

    # Choosing load-balance methodChoices are
    # <none|once|frequent|dynamic|dynamic_with_sparse_contacts>.
    set load balance method     = none

    # The particle weight based on a default cell weight of 1000
    set particle weight         = 2000

    # Step at which the triangulation is repartitioned and load is balanced
    # for single-step load-balancing
    set step                    = 100000

    # Threshold for dynamic load-balancing
    set threshold               = 0.5


    subsection cell weight function
      # Sometimes it is convenient to use symbolic constants in the expression
      # that describes the function, rather than having to use its numeric
      # value everywhere the constant appears. These values can be defined
      # using this parameter, in the form `var1=value1, var2=value2, ...'.
      # 
      # A typical example would be to set this runtime parameter to
      # `pi=3.1415926536' and then use `pi' in the expression of the actual
      # formula. (That said, for convenience this class actually defines both
      # `pi' and `Pi' by default, but you get the idea.)
      set Function constants  = 

      # The formula that denotes the function you want to evaluate for
      # particular values of the independent variables. This expression may
      # contain any of the usual operations such as addition or
      # multiplication, as well as all of the common functions such as `sin'
      # or `cos'. In addition, it may contain expressions like `if(x>0, 1,
      # -1)' where the expression evaluates to the second argument if the
      # first argument is true, and to the third argument otherwise. For a
      # full overview of possible expressions accepted see the documentation
      # of the muparser library at http://muparser.beltoforion.de/.
      # 
      # If the function you are describing represents a vector-valued function
      # with multiple components, then separate the expressions for individual
      # components by a semicolon.
      set Function expression = 0

      # The names of the variables as they will be used in the function,
      # separated by commas. By default, the names of variables at which the
      # function will be evaluated are `x' (in 1d), `x,y' (in 2d) or `x,y,z'
      # (in 3d) for spatial coordinates and `t' for time. You can then use
      # these variable names in your function expression and they will be
      # replaced by the values of these variables at which the function is
      # currently evaluated. However, you can also choose a different set of
      # names for the independent variables at which to evaluate your function
      # expression. For example, if you work in spherical coordinates, you may
      # wish to set this input parameter to `r,phi,theta,t' and then use these
      # variable names in your function expression.
      set Variable names      = x,y,t
    end

  end

end


subsection mortar
  # Center of rotation coordinates of rotor domain
  set center of rotation  = 0., 0.

  # Enable mortar interface <true|false>
  set enable              = false

  # Oversampling factor for quadrature points
  set oversampling factor = 1

  # Penalty factor for mortar elements
  set penalty factor      = 1.

  # Rotor boundary ID # of the mortar matching interface
  set rotor boundary id   = 1

  # Stator boundary ID # of the mortar matching interface
  set stator boundary id  = 2


  subsection mesh
    # Boundary ids of the boundaries to be initially refined
    set boundaries refined                  = 

    # Enables checking the input grid for diamond-shaped cells.
