    # Maximum solver iterations
    set max iters                                 = 1000

    # Maximum number of krylov vectors for GMRES
    set max krylov vectors                        = 100

    # The iterative solver for the linear system of equations. Choices are
    # <gmres|bicgstab|direct>.
    set method                                    = gmres

    # Use default parameters for Trilinos AMG
    set mg amg use default parameters             = false

    # The coarse grid solver for lsmg or gcmgChoices are
    # <gmres|amg|ilu|direct>.
    set mg coarse grid solver                     = direct

    # use elements with linear interpolation for coarse grid
    set mg coarse grid use fe q iso q1            = false

    # mg coarsening type for gcmg
    set mg coarsening type                        = h

    # Turns off the terms involving the hessian in the Jacobian of mg
    # operators
    set mg enable hessians in jacobian            = true

    # mg gmres iterations for lsmg or gcmg
    set mg gmres max iterations                   = 2000

    # mg gmres max krylov vectors for lsmg or gcmg
    set mg gmres max krylov vectors               = 30

    # The preconditioner for the mg gmres solverChoices are <amg|ilu>.
    set mg gmres preconditioner                   = amg

    # mg gmres reduce for lsmg or gcmg
    set mg gmres reduce                           = 1e-4

    # mg gmres tolerance n for lsmg or gcmg
    set mg gmres tolerance                        = 1e-14

    # mg int level
    set mg int level                              = -1

    # mg minimum number of cells for coarse level
    set mg level min cells                        = -1

    # mg min level
    set mg min level                              = -1

    # mg p coarsening type for gcmg
    set mg p coarsening type                      = decrease by one

    # estimate eigenvalues for relaxation parameter
    set mg smoother eig estimation                = false

    # mg smoother iterations for lsmg or gcmg
    set mg smoother iterations                    = 10

    # Preconditioner of smoother
    set mg smoother preconditioner type           = inverse diagonal

    # mg smoother relaxation for lsmg or gcmg
    set mg smoother relaxation                    = 0.5

    # State whether LSMG or GCMG should print information about levels Choices
    # are <quiet|verbose|extra verbose>.
    set mg verbosity                              = verbose

    # Linear solver minimum residual
    set minimum residual                          = 1e-12

    # The preconditioner for the linear solver.Choices are
    # <amg|ilu|lsmg|gcmg>.
    set preconditioner                            = ilu

    # Linear solver residual
    set relative residual                         = 1e-3

    # State whether output from solver runs should be printed. Choices are
    # <quiet|verbose|extra verbose>.
    set verbosity                                 = verbose
  end

