subsection boundary conditions
  # Bool to define if zero pressure is used as a constraint one node
  set fix pressure constant = false

  # Number of boundary conditions
  set number                = 4

  # Bool to define if the boundary condition is time dependent
  set time dependent        = false


  subsection bc 0
    # Penalty parameter for weak boundary condition imposed through Nitsche's
    # method or outlets
    set beta                     = 1

    # Thickness of the boundary layer used to calculate the penalty parameter
    # for partial slip boundary condition in tangent direction imposed through
    # Nitsche's method or outlets
    set boundary layer thickness = 0

    # Mesh id for boundary conditions. Default entry is -1 to ensure that the
    # id is set by the user
    set id                       = 0

    # Direction for periodic boundary condition
    set periodic_direction       = 0

    # Mesh id for periodic face matching. Default entry is -1 to ensure that
    # the periodic id is set by the user
    set periodic_id              = -1

    # Type of boundary conditionChoices are
    # <noslip|slip|function|periodic|pressure|function weak|partial
    # slip|outlet>.
    set type                     = function


    subsection center of rotation
      # X COR
      set x = 0

      # Y COR
      set y = 0

      # Z COR
      set z = 0
    end

