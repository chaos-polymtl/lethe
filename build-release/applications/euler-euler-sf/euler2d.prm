  subsection Nonlinear
    set picard max iterations = 300
    set picard tolerance      = 1e-8
  end

  subsection Output
    set digits  = 4
    set every   = 1
    set folder  = output/
    set prefix  = solid_phase
    set verbose = true
  end

  subsection Physics
    set beta  = 50.0
    set rho_s = 1.0
  end

  subsection Preconditioner
    set amg aggregation threshold = 0.02
    set amg elliptic              = false
    set amg smoother type         = ILU
    set amg sweeps                = 2
    set ilu overlap               = 1
  end

  subsection Solver
    set abs tol = 1e-12
    set max it  = 10000
    set rel tol = 1e-8
    set restart = 100
    set verbose = true
  end

  subsection Timers
    set print at end    = true
    set print each step = true
  end

end


subsection VOF
  # Enable phase compressibility in the VOF equation. This leads to the
  # inclusion of the phase * div(u) term in the VOF conservation equation. It
  # should be set to false when the phases are incompressible
  set compressible              = false

  # Diffusivity (diffusion coefficient in L^2/s) in the VOF transport
  # equation. Default value is 0 to have pure advection.
  set diffusivity               = 0

  # Fluid to which the viscous dissipation is applied in the heat equation
  # <fluid 0|fluid 1|both>
  set viscous dissipative fluid = fluid 1


  subsection interface regularization method
    # Reinitialization frequency (number of time-steps) at which the interface
    # regularization process will be applied to the VOF phase fraction field.
    set frequency = 10

    # VOF interface regularization method
    set type      = none

    # States whether the output from the interface regularization method
    # should be printed.Choices are <quiet|verbose|extra verbose>.
    set verbosity = quiet


    subsection algebraic interface reinitialization
      # Factor that multiplies the mesh-size in the mesh-dependant diffusion
      # coefficient of the algebraic interface reinitialization.
      set diffusivity multiplier        = 1.

      # Power value applied to the mesh-size in the mesh-dependant diffusion
      # coefficient of the algebraic interface reinitialization.
      set diffusivity power             = 1.

      # Maximum number of reinitialization steps.
      set max steps number              = 5

      # Enables pvtu format outputs of the algebraic interface
      # reinitialization steps <true|false>
      set output reinitialization steps = false

      # CFL value for pseudo-time-step calculation purposes in the algebraic
      # interface reinitialization.
      set reinitialization CFL          = 1.

      # Tolerance for the pseudo-time-stepping scheme.
      set steady-state criterion        = 1e-2
    end

    subsection geometric interface reinitialization
      # Maximum reinitialization distance value
      set max reinitialization distance = 1.

      # Enables pvtu format outputs of the geometric interface
      # reinitialization steps <true|false>
      set output signed distance        = false

      # Interface thickness for the tanh transformation
      set tanh thickness                = 1.
    end

    subsection projection-based interface sharpening
      # Sharpness of the moving interface (parameter alpha in the interface
      # sharpening model)
      set interface sharpness     = 2

      # Maximum number of iteration in the bissection algorithm that ensures
      # mass conservation
      set max iterations          = 20

      # Fluid for which conservation is monitored <fluid 0|fluid 1>, used with
      # adaptive sharpening.
      set monitored fluid         = fluid 1

      # Enable conservation monitoring in multiphase fluid simulations
      # <true|false>
      set monitoring              = false

      # Interface sharpening threshold that represents the phase fraction at
      # which the interphase is considered located
      set threshold               = 0.5

      # Maximum deviation (from the base value of 0.5) considered in the
      # search algorithm to ensure mass conservation. A threshold max
      # deviation of 0.20 results in a search interval from 0.30 to 0.70
      set threshold max deviation = 0.20

      # Tolerance on the mass conservation of the monitored fluid, used with
      # adaptive sharpening
      set tolerance               = 1e-6

      # VOF interface sharpening type, if constant the sharpening threshold is
      # the same throughout the simulation, if adaptive the sharpening
      # threshold is determined by binary search, to ensure mass conservation
      # of the monitored phase
      set type                    = constant
    end

  end

  subsection phase filtration
    # This parameter appears in the tanh filter function. It influence the
    # thickness and the shape of the interface. For higher values of beta, a
    # thinner and 'sharper/pixelated' interface will be seen.
    set beta      = 20

    # VOF phase filtration type, if <none> is selected, the phase won't be
    # filteredif <tanh> is selected, the filtered phase will be a result of
    # the following function: \alpha_f = 0.5 \tanh(\beta(\alpha-0.5)) + 0.5;
    # where \beta is a parameter influencing the interface thickness that must
    # be defined
    set type      = none

    # States whether the filtered data should be printed Choices are
    # <quiet|verbose>.
    set verbosity = quiet
  end

  subsection surface tension force
    # Factor applied to the filter for curvature calculations to damp
    # high-frequency errors
    set curvature diffusion factor               = 1

    # Enable surface tension force calculation <true|false>
    set enable                                   = false

    # Enable marangoni effect calculation <true|false>
    set enable marangoni effect                  = false

    # Output the phase fraction gradient and curvature
    set output auxiliary fields                  = false

    # Factor applied to the filter for phase fraction gradient calculations to
    # damp high-frequency errors
    set phase fraction gradient diffusion factor = 4

    # State whether the output from the surface tension force calculations
    # should be printed Choices are <quiet|verbose>.
    set verbosity                                = quiet
  end

end


subsection analytical solution
  # Enable the calculation of the analytical solution and L2 error
  set enable    = false

  # File name for the output for the L2Error table with respect to time or
  # mesh
  set filename  = L2Error

  # State whether from the post-processing values should be printed Choices
  # are <quiet|verbose>.
  set verbosity = quiet


