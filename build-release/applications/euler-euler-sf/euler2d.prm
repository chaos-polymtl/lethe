subsection insertion info
  # Initial angular velocity (x, y, z)
  set initial angular velocity                       = 0.0, 0.0, 0.0

  # Initial velocity (x, y, z)
  set initial velocity                               = 0.0, 0.0, 0.0

  # Inserted number of particles at each time step
  set inserted number of particles at each time step = 1

  # Coordinates of two points for the insertion box (x1, y1, z1 : x2, y2, z2)
  set insertion box points coordinates               = 0. , 0. , 0. : 1. , 1. , 1.

  # Direction of particle insertion for the volume insertion method
  set insertion direction sequence                   = 0,1,2

  # Distance threshold
  set insertion distance threshold                   = 1.

  # Insertion frequency
  set insertion frequency                            = 1

  # Maximum position offset when insertion of particles
  set insertion maximum offset                       = 1.

  # Choosing insertion method. Choices are <file|plane|list|volume>.
  set insertion method                               = volume

  # Insertion plane normal vector
  set insertion plane normal vector                  = 1., 0., 0.

  # Insertion plane point location
  set insertion plane point                          = 0., 0., 0.

  # If all the vertices of a cell are closer or equal to this value, than this
  # cell is in the plane
  set insertion plane threshold distance             = 0.

  # Pseudo-random number seed used to generate the position offsets
  set insertion prn seed                             = 1

  # List of diameters
  set list diameters                                 = -1.0

  # The file name from which we load the particles
  set list of input files                            = particles.input

  # List of initial omega x
  set list omega x                                   = 0.

  # List of initial omega y
  set list omega y                                   = 0.

  # List of initial omega z
  set list omega z                                   = 0.

  # List of initial temperatures
  set list temperatures                              = 0.

  # List of initial velocities x
  set list velocity x                                = 0

  # List of initial velocities y
  set list velocity y                                = 0

  # List of initial velocities z
  set list velocity z                                = 0

  # List of particles x positions
  set list x                                         = 0

  # List of particles y positions
  set list y                                         = 0

  # List of particles z positions
  set list z                                         = 0

  # Coordinates of two points for the removal box (x1, y1, z1 : x2, y2, z2)
  set removal box points coordinates                 = 0. , 0. , 0. : 1. , 1. , 1.

  # State whether particles should be cleared on insertion.
  set remove particles                               = false


  subsection initial temperature function
    # Sometimes it is convenient to use symbolic constants in the expression
    # that describes the function, rather than having to use its numeric value
    # everywhere the constant appears. These values can be defined using this
    # parameter, in the form `var1=value1, var2=value2, ...'.
    # 
    # A typical example would be to set this runtime parameter to
    # `pi=3.1415926536' and then use `pi' in the expression of the actual
    # formula. (That said, for convenience this class actually defines both
    # `pi' and `Pi' by default, but you get the idea.)
    set Function constants  = 

    # The formula that denotes the function you want to evaluate for
    # particular values of the independent variables. This expression may
    # contain any of the usual operations such as addition or multiplication,
    # as well as all of the common functions such as `sin' or `cos'. In
    # addition, it may contain expressions like `if(x>0, 1, -1)' where the
    # expression evaluates to the second argument if the first argument is
    # true, and to the third argument otherwise. For a full overview of
    # possible expressions accepted see the documentation of the muparser
    # library at http://muparser.beltoforion.de/.
    # 
    # If the function you are describing represents a vector-valued function
    # with multiple components, then separate the expressions for individual
    # components by a semicolon.
    set Function expression = 0

    # The names of the variables as they will be used in the function,
    # separated by commas. By default, the names of variables at which the
    # function will be evaluated are `x' (in 1d), `x,y' (in 2d) or `x,y,z' (in
    # 3d) for spatial coordinates and `t' for time. You can then use these
    # variable names in your function expression and they will be replaced by
    # the values of these variables at which the function is currently
    # evaluated. However, you can also choose a different set of names for the
    # independent variables at which to evaluate your function expression. For
    # example, if you work in spherical coordinates, you may wish to set this
    # input parameter to `r,phi,theta,t' and then use these variable names in
    # your function expression.
    set Variable names      = x,y,t
  end

end


subsection lagrangian physical properties
  # Dynamic viscosity of interstitial gas
  set dynamic viscosity gas        = 1.e-5

  # Friction coefficient of wall
  set friction coefficient wall    = 0.1

  # Gravitational acceleration vector
  set g                            = 0., 0., 0.

  # Gravitational acceleration in y direction (deprecated, use <g> as vector)
  set gy                           = 0.

  # Gravitational acceleration in z direction (deprecated, use <g> as vector)
  set gz                           = 0.

  # Hamaker constant of wall
  set hamaker constant wall        = 4.e-19

  # Molecular mean free path of interstitial gas
  set molecular mean free path gas = 68.e-9

  # Number of particle types
  set number of particle types     = 1

  # Poisson's ratio of wall
  set poisson ratio wall           = 0.3

  # Coefficient of restitution of wall
  set restitution coefficient wall = 0.1

  # Rolling friction coefficient of wall
  set rolling friction wall        = 0.1

  # Rolling viscous damping wall
  set rolling viscous damping wall = 0.1

  # Specific heat of interstitial gas
  set specific heat gas            = 1000

  # Specific heats ratio of interstitial gas
  set specific heats ratio gas     = 1

  # Surface energy of wall
  set surface energy wall          = 0.0

  # Thermal conductivity of interstitial gas
  set thermal conductivity gas     = 0.01

  # Young's modulus of wall
  set young modulus wall           = 1000000.


  subsection particle type 0
    # Diameter values for a custom distribution
