    subsection physical properties
      # density of the particle
      set density                      = 1

      # The friction coefficient of particle in case of contact
      set friction coefficient         = 0

      # Moments of inertia of the particle in the reference frame of the
      # fluid. The entry sequence corresponds to : I_xx ;I_xy ;I_xz ;I_yx
      # ;I_yy ;I_yz ;I_zx ;I_zy ;I_zz
      set inertia                      = 1 ;0 ;0 ;0 ;1 ;0 ;0 ;0 ;1

      # The poisson ratio of particle in case of contact
      set poisson ratio                = 0.3

      # The restitution coefficient of particle in case of contact
      set restitution coefficient      = 1

      # The rolling friction coefficient of particle in case of contact
      set rolling friction coefficient = 0

      # The volume occupied by the particle. If it is left empty, the volume
      # is automatically calculated if possible otherwise the volume of a
      # sphere is used instead
      set volume                       = 0

      # The Young's modulus of particle in case of contact
      set youngs modulus               = 100000000
    end

