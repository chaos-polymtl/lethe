    end

    subsection wall physical properties
      # The wall friction coefficient if IB particles are in contact with it
      set wall friction coefficient         = 0

      # The wall poisson ratio if IB particles are in contact with it
      set wall poisson ratio                = 0.3

      # The wall restitution coefficient if IB particles are in contact with
      # it
      set wall restitution coefficient      = 1

      # The wall rolling friction coefficient if IB particles are in contact
      # with it
      set wall rolling friction coefficient = 0

      # The wall Young's modulus if IB particles are in contact with it
      set wall youngs modulus               = 100000000
    end

  end

  subsection extrapolation function
    # Bool to define if extrapolation should be enabled (default). If
    # disabled, all velocity degrees of freedom in a cell will be set to the
    # particle velocity if that cell is cut. Setting to false is intended for
    # debugging purposes.
    set enable extrapolation = true

    # The length ratio used to define the points for the IB stencil. See
    # definition of epsilon_n in the paper on sharp IB.
    set length ratio         = 4

    # The polynomial order used in the extrapolation function
    set stencil order        = 2
  end

  subsection input file
    # Bool to define if particles are loaded from an external file
    set load particles from file = false

    # The file name from which we load the particles
    set particles file           = particles
  end

  subsection local mesh refinement
    # Number of refinements around the particles before the start of the
    # simulation
    set initial refinement                = 0

    # The factor that multiplies the radius to define the inside bound for the
    # refinement of the mesh
    set refine mesh inside radius factor  = 0.5

    # The factor that multiplies the radius to define the outside bound for
    # the refinement of the mesh
    set refine mesh outside radius factor = 1.5

    # This parameter enables the extrapolation in time of the refinement zone.
    # This means that it will try to refine where the particle will be at the
    # end of the time step instead of the initial position.
    set refinement zone extrapolation     = false
  end

  subsection output
    # Bool to define if the force is evaluated on each particle
    set calculate force                               = true

    # This parameter enables the output of more information related to the
    # particles in the vtu file.
    set enable extra sharp interface vtu output field = false

    # The name of the file where the data on the force of each particle is
    # stored
    set ib force output file                          = ib_force

    # The output files of the pvd data for the ib particles
    set ib particles pvd file                         = ib_particles_data

    # Bool to define if particles' informations are printed on the terminal
    # when particles' time-step is finished
    set print DEM                                     = true
  end

  subsection particle info 0
    # Bool to define if the particle trajectory is integrated meaning its
    # velocity and position will be updated at each time step according to the
    # hydrodynamic force applied to it
    set integrate motion           = false

    # Thickness (positive or negative) of uniform additional layer of solid on
    # particle.A negative value will decrease the particle's thickness by
    # subtracting a layer of specified width.
    set layer thickening           = 0

    # Bool to define if precalculations should be performed between
    # refinements. Precalculations can introduce shape deformation when the
    # type is RBF and some nodes are located outside the background mesh.
    set mesh-based precalculations = true

    # position relative to the center of the particle for the location of the
    # point where the pressure is imposed inside the particle
    set pressure location          = 0; 0; 0

    # Arguments defining the geometry
    set shape arguments            = 1

    # The type of shape considered.Choices are <sphere|hyper
    # rectangle|ellipsoid|torus|cone|cylinder|cylindrical tube|cylindrical
    # helix|cut hollow sphere|death
    # star|superquadric|rbf|opencascade|composite>.The parameter for a sphere
    # is: radius. The parameters for a hyper rectangle are, in order: x half
    # length,y half length, z half length.The parameters for an ellipsoid are,
    # in order: x radius,y radius, z radius. The parameters for a torus are,
    # in order: torus radius,torus thickness radius. The parameters for a cone
    # are, in order: tan(base angle), height. The parameters for a cylinder
    # are, in order: radius, half-length.It is aligned to the z axis by
    # default.The parameters for a cylindrical tube are, in order: inside
    # radius,outside radius, half-length. It is aligned to the z axis by
    # default.The parameters for a cylindrical helix are, in order: helix
    # radius,tube radius, helix total height, pitch (height between two
    # consecutive loops).The parameters for a cut hollow sphere are, in order:
    # sphere radius,cut thickness, wall thickness. The parameters for a death
    # star are, in order: sphere radius,smaller sphere radius, distance
    # between centers.The parameters for a superquadric are, in order: a, b,
    # c, r, s, t, epsilon. The first three are half-lengths in x, y, and z.The
    # next three are the blockiness in the x, y, and z directions.The last is
    # the tolerance of the found surface.The parameter for an rbf is the file
    # name.The parameter for a composite is the file name.
    set type                       = sphere


